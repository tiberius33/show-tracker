# Firebase Configuration
# Copy this file to .env and fill in your values
# For Netlify deploys, set these in Site settings → Environment variables

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# Setlist.fm API (server-side only — no REACT_APP_ prefix)
SETLISTFM_API_KEY=

# Ticketmaster Discovery API (server-side only — no REACT_APP_ prefix)
TICKETMASTER_API_KEY=
TICKETMASTER_AFFILIATE_ID=

# SeatGeek API (server-side only — no REACT_APP_ prefix)
SEATGEEK_CLIENT_ID=
SEATGEEK_AFFILIATE_ID=

# Setlist.fm server-side cache (Netlify Functions only — never expose to client)
# FIREBASE_SERVICE_ACCOUNT_JSON: minified JSON from Firebase Console → Project Settings → Service Accounts
# FIREBASE_PROJECT_ID: your Firebase project ID (e.g. my-app-12345)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=

# Spotify API (PKCE OAuth flow for playlist creation)
# Create an app at https://developer.spotify.com/dashboard
# NEXT_PUBLIC_ prefix is required — it's used client-side to build the auth URL
# Also set SPOTIFY_CLIENT_ID (same value) for the Netlify function token exchange
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_ID=

# Apple Music API (for playlist creation)
# Generate a MusicKit private key in your Apple Developer account
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=

# Discogs API (optional — improves artist enrichment rate limits from 25 to 60 req/min)
# Get a personal access token at https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# Anthropic API Key (for screenshot import feature)
# Required for AI-powered screenshot analysis of ticket platform event history
ANTHROPIC_API_KEY=

# ─── Test Suite Configuration ──────────────────────────────────────────────────
# Copy these into your Netlify environment variables / GitHub Actions secrets

# URL to test against (defaults to https://mysetlists.net)
TEST_BASE_URL=https://mysetlists.net

# Environment tag shown in Notion test reports ('local' | 'staging' | 'production')
ENVIRONMENT=production

# Primary test account (pre-existing Firebase email/password account)
TEST_EMAIL=
TEST_PASSWORD=

# Secondary test account (for friend-tagging and social integration tests)
TEST_EMAIL_2=
TEST_PASSWORD_2=

# Firebase UID of the primary test account (used by cleanup.js)
TEST_FIREBASE_UID=

# Notion test database (receives pass/fail results after each test run)
# Create a database with: Test Run (title), Passed/Failed/Total/Duration (number),
# Status (status), Suite (rich_text), Environment (select)
NOTION_API_KEY=
NOTION_TEST_DATABASE_ID=

# Admin secret for the /.netlify/functions/run-tests endpoint (optional)
# If not set, the endpoint is unauthenticated (fine for internal use)
TEST_ADMIN_SECRET=

# Opt-in flags for expensive / side-effectful tests
# TEST_SEND_REAL_EMAIL=true      — send a real email via Resend in email smoke test
# TEST_PLAYLISTS_FULL=true       — create a real Spotify playlist (needs token below)
# TEST_AI_SCAN_FULL=true         — run OCR against a sample ticket image
# TEST_NOTIFICATIONS_FULL=true   — validate notification delivery end-to-end
TEST_SEND_REAL_EMAIL=
TEST_PLAYLISTS_FULL=
TEST_AI_SCAN_FULL=
TEST_NOTIFICATIONS_FULL=

# Pre-obtained Spotify access token for full playlist creation tests
TEST_SPOTIFY_ACCESS_TOKEN=

# Resend API key (for email delivery smoke test)
RESEND_API_KEY=
