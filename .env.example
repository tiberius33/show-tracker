# Firebase Configuration
# Copy this file to .env and fill in your values
# For Netlify deploys, set these in Site settings → Environment variables

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# Setlist.fm API (server-side only — no REACT_APP_ prefix)
SETLISTFM_API_KEY=

# Ticketmaster Discovery API (server-side only — no REACT_APP_ prefix)
TICKETMASTER_API_KEY=
TICKETMASTER_AFFILIATE_ID=

# SeatGeek API (server-side only — no REACT_APP_ prefix)
SEATGEEK_CLIENT_ID=
SEATGEEK_AFFILIATE_ID=

# Setlist.fm server-side cache (Netlify Functions only — never expose to client)
# FIREBASE_SERVICE_ACCOUNT_JSON: minified JSON from Firebase Console → Project Settings → Service Accounts
# FIREBASE_PROJECT_ID: your Firebase project ID (e.g. my-app-12345)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=

# Spotify API (PKCE OAuth flow for playlist creation)
# Create an app at https://developer.spotify.com/dashboard
# NEXT_PUBLIC_ prefix is required — it's used client-side to build the auth URL
# Also set SPOTIFY_CLIENT_ID (same value) for the Netlify function token exchange
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_ID=

# Apple Music API (for playlist creation)
# Generate a MusicKit private key in your Apple Developer account
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=

# Discogs API (optional — improves artist enrichment rate limits from 25 to 60 req/min)
# Get a personal access token at https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# Anthropic API Key (for screenshot import feature)
# Required for AI-powered screenshot analysis of ticket platform event history
ANTHROPIC_API_KEY=
