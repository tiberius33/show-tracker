# Firebase Configuration
# Copy this file to .env and fill in your values
# For Netlify deploys, set these in Site settings → Environment variables

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# Ticketmaster Discovery API (server-side only — no REACT_APP_ prefix)
TICKETMASTER_API_KEY=
TICKETMASTER_AFFILIATE_ID=

# SeatGeek API (server-side only — no REACT_APP_ prefix)
SEATGEEK_CLIENT_ID=
SEATGEEK_AFFILIATE_ID=
